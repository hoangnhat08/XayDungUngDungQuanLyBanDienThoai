# data/*.xlsx
# data/*.json

# Models saved during training
models/
*.pkl
*.joblib
*.h5
*.pth
*.pt

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Large files (if any)
*.zip
*.tar.gz
*.rar

# Reports (optional - usually generated files)
# reports/*.pdf
# reports/*.docx
